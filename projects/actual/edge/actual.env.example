# External port on your Docker host (container is always 5006)
ACTUAL_HOST_PORT=5006

# Optional: If you self-terminate TLS inside Actual (usually NOT needed if you use a reverse proxy)
# ACTUAL_HTTPS_KEY=/data/selfhost.key
# ACTUAL_HTTPS_CERT=/data/selfhost.crt

# Optional: upload limits (defaults exist; only set if you need to)
# ACTUAL_UPLOAD_FILE_SYNC_SIZE_LIMIT_MB=20
# ACTUAL_UPLOAD_SYNC_ENCRYPTED_FILE_SYNC_SIZE_LIMIT_MB=50
# ACTUAL_UPLOAD_FILE_SIZE_LIMIT_MB=20